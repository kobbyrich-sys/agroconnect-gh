{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@agroconnect/ui": [
        "../../packages/ui/src"
      ],
      "@agroconnect/models": [
        "../../packages/models/src"
      ],
      "@agroconnect/shared": [
        "../../packages/shared/src"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
