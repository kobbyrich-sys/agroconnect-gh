{
  "name": "agroconnect-gh",
  "version": "1.0.0",
  "private": true,
  "description": "AgroConnect GH - Ghana's digital agricultural and manufacturing marketplace",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prettier": "^3.5.0",
    "turbo": "^2.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "framer-motion": "^12.4.0",
    "jose": "^6.2.3",
    "pg": "^8.22.0"
  }
}
